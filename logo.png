<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Humanities AI in an East Asian Context — TRIP 2026 · NTU</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700&family=Libre+Franklin:wght@300;400;500;600&family=Noto+Serif+TC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#F4EFE3;
    --paper-2:#ECE4D2;
    --ink:#1B2A4A;          /* 青 — qing indigo */
    --ink-soft:#42527A;
    --cinnabar:#B23A2E;     /* 朱 — reserved for the seal only */
    --celadon:#5E7E6E;      /* 青瓷 */
    --gold:#A98B53;
    --muted:#6E6552;
    --hair:rgba(27,42,74,.16);

    --display:"Fraunces",Georgia,"Noto Serif TC",serif;
    --sans:"Libre Franklin",system-ui,"Noto Sans TC",sans-serif;
    --cjk:"Noto Serif TC","Songti TC",serif;
    --seal:"Baoli SC","Baoli TC","Weibei SC","STLiti","LiSu","DFLiShu","隶书",var(--cjk);
  }

  *{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%}
  body{
    background:var(--paper);
    color:var(--ink);
    font-family:var(--sans);
    overflow:hidden;
    -webkit-font-smoothing:antialiased;
  }

  body::before{
    content:"";position:fixed;inset:0;pointer-events:none;z-index:0;
    background-image:
      linear-gradient(var(--hair) 1px,transparent 1px),
      linear-gradient(90deg,var(--hair) 1px,transparent 1px);
    background-size:54px 54px;
    opacity:.20;
    mask-image:radial-gradient(ellipse 120% 110% at 50% 50%,#000 35%,transparent 92%);
  }
  body::after{
    content:"";position:fixed;inset:0;pointer-events:none;z-index:0;
    background:radial-gradient(circle at 18% 12%,rgba(255,255,255,.5),transparent 42%),
               radial-gradient(circle at 88% 90%,rgba(27,42,74,.05),transparent 50%);
  }

  .stage{position:fixed;inset:0;z-index:1}
  .slide{
    position:absolute;inset:0;
    display:flex;align-items:center;justify-content:center;
    padding:5.2vh 6.2vw;
    opacity:0;visibility:hidden;
    transform:translateY(10px) scale(.995);
    transition:opacity .55s ease,transform .55s ease,visibility .55s;
  }
  .slide.active{opacity:1;visibility:visible;transform:none}
  .inner{width:100%;max-width:1180px;position:relative}

  .r{opacity:0;transform:translateY(16px);transition:opacity .7s cubic-bezier(.2,.7,.2,1),transform .7s cubic-bezier(.2,.7,.2,1)}
  .active .r{opacity:1;transform:none}
  .active .r:nth-child(1){transition-delay:.10s}
  .active .r:nth-child(2){transition-delay:.20s}
  .active .r:nth-child(3){transition-delay:.30s}
  .active .r:nth-child(4){transition-delay:.40s}
  .active .r:nth-child(5){transition-delay:.50s}
  .active .r:nth-child(6){transition-delay:.60s}

  .kicker{
    font-family:var(--sans);font-weight:600;
    font-size:clamp(.66rem,1vw,.82rem);
    letter-spacing:.32em;text-transform:uppercase;
    color:var(--cinnabar);
    display:flex;align-items:center;gap:.85em;margin-bottom:2.4vh;
  }
  .kicker .num{font-family:var(--display);font-weight:500;letter-spacing:.05em;color:var(--ink);font-size:1.05em}
  .kicker .bar{height:1px;width:46px;background:var(--gold)}

  h1{font-family:var(--display);font-weight:500;font-size:clamp(2.1rem,5.4vw,4.1rem);line-height:1.02;letter-spacing:-.015em}
  h2{font-family:var(--display);font-weight:500;font-size:clamp(1.7rem,3.6vw,2.85rem);line-height:1.06;letter-spacing:-.01em;margin-bottom:2vh}
  .lead{font-size:clamp(1.02rem,1.7vw,1.34rem);line-height:1.62;max-width:46ch;color:var(--ink-soft);font-weight:300;margin-top:2.4vh}
  .lead strong{color:var(--ink);font-weight:600}
  em.q{color:var(--cinnabar);font-style:italic}
  .cjk{font-family:var(--cjk)}

  /* ---------- 人文共智 carved seal (rendered PNG) ---------- */
  .seal{position:absolute;right:6.2vw;bottom:4.4vh;z-index:3;width:62px;height:62px;
    background:url(data:image/png;base64,) center/contain no-repeat;
    filter:drop-shadow(0 3px 9px rgba(178,58,46,.30));opacity:.96;}

  /* ---------- cover ---------- */
  .cover .inner{max-width:1240px}
  .cover-grid{display:grid;grid-template-columns:.92fr 1.08fr;gap:5%;align-items:center}
  @media(max-width:920px){.cover-grid{grid-template-columns:1fr;gap:3.4vh}}
  .logo-card{
    position:relative;border-radius:18px;padding:7% 8%;
    background:radial-gradient(circle at 38% 40%,#16261d 0%,#0c1310 62%,#080c0a 100%);
    border:1px solid rgba(168,139,83,.25);
    box-shadow:0 22px 60px rgba(8,12,10,.4),inset 0 0 60px rgba(94,126,110,.08);
  }
  .logo-card img{display:block;width:100%;height:auto;filter:drop-shadow(0 6px 18px rgba(0,0,0,.4))}
  .cover .expand{font-family:var(--display);font-weight:500;font-size:clamp(1.9rem,4vw,3.1rem);line-height:1.04;letter-spacing:-.015em;color:var(--ink)}
  .cover .expand em{font-style:italic;color:var(--cinnabar)}
  .cover .toplabel{font-size:.68rem;letter-spacing:.26em;text-transform:uppercase;color:var(--cinnabar);font-weight:600;margin-bottom:2.2vh}
  .cover .sub{font-size:clamp(.92rem,1.4vw,1.12rem);color:var(--ink-soft);font-weight:300;margin-top:2.6vh;line-height:1.6;max-width:46ch}
  .cover .greet{font-family:var(--cjk);font-weight:400;color:var(--celadon);margin-top:2.2vh;font-size:clamp(.95rem,1.5vw,1.15rem);letter-spacing:.04em}
  .cover .meta{margin-top:3.6vh;display:flex;gap:1.4em;flex-wrap:wrap;align-items:center;font-size:.76rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
  .cover .meta .dot{width:5px;height:5px;border-radius:50%;background:var(--gold)}

  .cols{display:grid;grid-template-columns:1.05fr .95fr;gap:5.5%;align-items:center}
  @media(max-width:900px){.cols{grid-template-columns:1fr;gap:3vh}}

  .pull{font-family:var(--display);font-weight:400;font-style:italic;font-size:clamp(1.3rem,2.6vw,2rem);line-height:1.28;color:var(--ink);border-left:2px solid var(--cinnabar);padding-left:1.1em}
  .pull .small{display:block;font-style:normal;font-family:var(--sans);font-weight:500;font-size:.5em;letter-spacing:.04em;color:var(--muted);margin-top:1em}

  .stat-row{display:flex;gap:2.6em;flex-wrap:wrap;margin-top:3.4vh}
  .stat .big{font-family:var(--display);font-weight:600;font-size:clamp(1.8rem,3.4vw,2.7rem);color:var(--cinnabar);line-height:1}
  .stat .cap{font-size:.82rem;color:var(--ink-soft);margin-top:.5em;letter-spacing:.02em;max-width:18ch}

  .flow{display:flex;flex-direction:column;gap:1.1vh;margin-top:1vh}
  .step{display:flex;align-items:flex-start;gap:1em;padding:1.05em 1.2em;background:rgba(255,255,255,.45);border:1px solid var(--hair);border-radius:12px;backdrop-filter:blur(2px)}
  .step .idx{font-family:var(--display);font-weight:600;color:var(--cinnabar);font-size:1.1rem;min-width:1.4em}
  .step .role{font-weight:600;font-size:1rem;color:var(--ink)}
  .step .role .zh{font-family:var(--cjk);font-weight:500;color:var(--celadon);margin-left:.5em;font-size:.9em}
  .step .desc{font-size:.9rem;color:var(--ink-soft);font-weight:300;line-height:1.5;margin-top:.15em}

  .sutra{display:grid;grid-template-columns:1fr 1fr 1.15fr;gap:14px;margin-top:1.2vh}
  @media(max-width:1000px){.sutra{grid-template-columns:1fr}}
  .panel{background:rgba(255,255,255,.55);border:1px solid var(--hair);border-radius:13px;padding:1.1em 1.15em;min-height:30vh;display:flex;flex-direction:column}
  .panel .head{font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;color:var(--cinnabar);font-weight:600;margin-bottom:.9em;display:flex;justify-content:space-between;align-items:center}
  .panel .head .who{color:var(--muted);font-weight:500;letter-spacing:.04em;text-transform:none;font-size:.78rem}
  .scripture{font-family:var(--cjk);font-size:clamp(.95rem,1.5vw,1.18rem);line-height:2;color:var(--ink-soft);font-weight:400}
  .scripture .dim{opacity:.4}
  .phrase{cursor:pointer;border-radius:5px;padding:.05em .18em;transition:.3s;color:var(--ink);box-shadow:inset 0 -0.62em 0 rgba(178,58,46,.16)}
  .phrase:hover{box-shadow:inset 0 -0.62em 0 rgba(178,58,46,.32)}
  .phrase.lit{background:rgba(178,58,46,.16);color:var(--cinnabar);font-weight:500;box-shadow:none}
  .phrase.matched{background:rgba(94,126,110,.18);color:var(--celadon);box-shadow:none;font-weight:500}
  .hint-tap{font-size:.72rem;color:var(--muted);margin-top:auto;padding-top:.8em;font-style:italic}

  .agent-panel{position:relative}
  .tabs{display:flex;gap:.35em;margin-bottom:.9em;flex-wrap:wrap}
  .tab{font-size:.72rem;font-weight:600;letter-spacing:.04em;padding:.42em .72em;border-radius:7px;border:1px solid var(--hair);background:transparent;color:var(--ink-soft);cursor:pointer;transition:.2s;font-family:var(--sans)}
  .tab.on{background:var(--ink);color:var(--paper);border-color:var(--ink)}
  .agent-body{font-size:.9rem;line-height:1.56;color:var(--ink-soft);font-weight:300;min-height:9.5em}
  .agent-body.empty{display:flex;align-items:center;justify-content:center;text-align:center;color:var(--muted);font-style:italic}
  .agent-body .conf{display:inline-flex;align-items:center;gap:.5em;margin-top:1em;font-size:.72rem;letter-spacing:.06em;text-transform:uppercase;font-weight:600}
  .badge{padding:.18em .6em;border-radius:20px;font-size:.66rem}
  .badge.med{background:rgba(169,139,83,.2);color:var(--gold)}
  .badge.low{background:rgba(178,58,46,.16);color:var(--cinnabar)}
  .agent-body .ev{display:block;margin-top:.7em;font-size:.74rem;color:var(--muted);font-family:var(--display)}
  .proto-tag{position:absolute;top:-2.4vh;right:0;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);font-weight:600}

  .field-wrap{margin-top:1vh;display:grid;grid-template-columns:1.45fr 1fr;gap:4%;align-items:center}
  @media(max-width:960px){.field-wrap{grid-template-columns:1fr}}
  .field-box{background:rgba(255,255,255,.4);border:1px solid var(--hair);border-radius:14px;overflow:hidden;aspect-ratio:1040/640;width:100%}
  .field-box svg{display:block;width:100%;height:100%}
  .field-note .lead{margin-top:0}
  .formula{font-family:var(--display);font-size:.95rem;color:var(--ink-soft);margin-top:2vh;padding:.9em 1.1em;border:1px dashed var(--hair);border-radius:10px;background:rgba(255,255,255,.3)}
  .formula b{color:var(--cinnabar);font-style:italic}
  .cite{font-size:.78rem;color:var(--muted);margin-top:1.4vh;font-style:italic}

  .mdcard{background:var(--ink);color:var(--paper);border-radius:14px;padding:1.5em 1.6em;font-family:"SFMono-Regular",ui-monospace,Menlo,monospace;font-size:.84rem;line-height:1.75;box-shadow:0 18px 50px rgba(27,42,74,.28)}
  .mdcard .fn{color:#9FB4D8;font-size:.72rem;letter-spacing:.1em;margin-bottom:1em;border-bottom:1px solid rgba(255,255,255,.12);padding-bottom:.7em}
  .mdcard .h{color:#E7C97A}
  .mdcard .c{color:#7E93B8}
  .mdcard .k{color:#E89A8C}
  .mdcard .v{color:#A9C9B6}
  .mdcard .cursor{display:inline-block;width:.5em;height:1.05em;background:#E7C97A;vertical-align:-2px;margin-left:2px;animation:blink 1.1s steps(1) infinite}
  @keyframes blink{50%{opacity:0}}

  .alliance{display:flex;gap:1.2em;flex-wrap:wrap;margin-top:3vh}
  .uni{border:1px solid var(--hair);border-radius:11px;padding:1em 1.2em;background:rgba(255,255,255,.4);min-width:150px}
  .uni .en{font-weight:600;font-size:.96rem;color:var(--ink)}
  .uni .nat{font-family:var(--cjk);color:var(--celadon);font-size:.86rem;margin-top:.25em}
  .slogan{font-family:var(--display);font-style:italic;font-weight:400;font-size:clamp(1.3rem,2.7vw,2rem);line-height:1.3;color:var(--ink);margin-top:3.5vh}
  .slogan .em{color:var(--cinnabar)}
  .thanks{margin-top:3vh;display:flex;gap:1.4em;flex-wrap:wrap;font-family:var(--cjk);color:var(--ink-soft);font-size:clamp(1rem,1.7vw,1.3rem)}
  .thanks span:not(:last-child){border-right:1px solid var(--hair);padding-right:1.4em}

  .topbar{position:fixed;top:0;left:0;right:0;height:3px;z-index:6;background:transparent}
  .topbar .fill{height:100%;background:linear-gradient(90deg,var(--cinnabar),var(--gold));width:0;transition:width .5s ease}
  .counter{position:fixed;top:2.4vh;right:6.2vw;z-index:6;font-family:var(--display);font-weight:500;font-size:.86rem;color:var(--ink);letter-spacing:.08em}
  .counter b{color:var(--cinnabar)}
  .brand-tag{position:fixed;top:2.4vh;left:6.2vw;z-index:6;font-size:.66rem;letter-spacing:.26em;text-transform:uppercase;color:var(--muted);font-weight:600}

  .nav{position:fixed;bottom:3.4vh;left:50%;transform:translateX(-50%);z-index:6;display:flex;align-items:center;gap:1.2em}
  .arrow{width:34px;height:34px;border-radius:50%;border:1px solid var(--hair);background:rgba(255,255,255,.5);color:var(--ink);cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:.2s}
  .arrow:hover{background:var(--ink);color:var(--paper);border-color:var(--ink)}
  .dots{display:flex;gap:.6em}
  .dot-nav{width:8px;height:8px;border-radius:50%;background:var(--hair);cursor:pointer;transition:.25s}
  .dot-nav.on{background:var(--cinnabar);transform:scale(1.35)}

  .help{position:fixed;bottom:3.6vh;right:6.2vw;z-index:6;font-size:.68rem;color:var(--muted);letter-spacing:.04em}
  .help kbd{font-family:var(--display);background:rgba(27,42,74,.07);border:1px solid var(--hair);border-radius:4px;padding:.05em .42em;font-size:.92em}

  .notes{position:fixed;left:0;right:0;bottom:0;z-index:8;background:rgba(27,42,74,.97);color:var(--paper);padding:1.6em 6.2vw 2em;transform:translateY(102%);transition:transform .4s ease;max-height:46vh;overflow:auto}
  .notes.show{transform:none}
  .notes .lbl{font-size:.66rem;letter-spacing:.24em;text-transform:uppercase;color:#E7C97A;font-weight:600;margin-bottom:.7em}
  .notes p{font-size:clamp(.95rem,1.5vw,1.18rem);line-height:1.62;font-weight:300;max-width:90ch}

  @media print{.nav,.help,.counter,.topbar,.brand-tag,.notes{display:none}}
</style>
</head>
<body>

<div class="topbar"><div class="fill" id="fill"></div></div>
<div class="brand-tag">TRIP 2026 · Embodied Humanities</div>
<div class="counter"><b id="cur">01</b> / <span id="tot">09</span></div>

<div class="stage" id="stage">

  <!-- 1 · COVER -->
  <section class="slide cover active">
    <div class="inner">
      <div class="cover-grid">
        <div class="logo-card r">
          <img src="data:image/png;base64," alt="CHAI — Co-Intelligence Humanities AI Future Lab">
        </div>
        <div>
          <div class="toplabel r">TRIP 2026 · NTU College of Liberal Arts</div>
          <h1 class="r" style="font-size:clamp(1.55rem,3.1vw,2.55rem);line-height:1.07;letter-spacing:-.01em">Humanities AI in an<br>East Asian Context</h1>
          <div class="r" style="font-family:var(--display);font-size:clamp(.98rem,1.6vw,1.3rem);color:var(--ink-soft);font-weight:400;margin-top:1.4vh;line-height:1.3">Language, Culture &amp; Computational Practice</div>
          <div class="r" style="margin-top:2.6vh;display:flex;align-items:center;gap:.8em">
            <span style="height:1px;width:34px;background:var(--cinnabar);display:inline-block"></span>
            <span style="font-family:var(--display);font-style:italic;font-size:clamp(.98rem,1.6vw,1.28rem);color:var(--ink)">Co-Intelligence of Humanities &amp; <em style="color:var(--cinnabar)">AI</em></span>
          </div>
          <div class="greet cjk r">九州大学・京都大学・고려대학교 — ようこそ、환영합니다、歡迎。</div>
          <div class="meta r"><span>Shu-Kai Hsieh</span><span class="dot"></span><span>10-minute talk</span></div>
        </div>
      </div>
    </div>
    <div class="seal" aria-label="人文共智"></div>
  </section>

  <!-- 2 · WHY HUMANITIES -->
  <section class="slide">
    <div class="inner">
      <div class="cols">
        <div>
          <div class="kicker r"><span class="num">01</span><span class="bar"></span> Why the humanities matter <em style="font-style:italic;color:var(--ink);text-transform:none;letter-spacing:0;margin-left:.3em">more</em></div>
          <h1 class="r">Cheap fluency,<br>expensive meaning.</h1>
          <p class="lead r">When any machine can generate plausible text in any voice at near-zero cost, <strong>fluency stops being scarce.</strong> What becomes precious is <strong>meaning</strong> — interpretation, provenance, judgment, the weight of a word across centuries.</p>
        </div>
        <div>
          <div class="pull r">The flood of generated language is precisely why we need cartographers of meaning.
            <span class="small">AI does not endanger the humanities — it raises their value.</span>
          </div>
          <div class="stat-row r">
            <div class="stat"><div class="big">2,000 yrs</div><div class="cap">of reading, interpreting, judging — the humanist's core craft</div></div>
            <div class="stat"><div class="big">~0</div><div class="cap">marginal cost of fluent text in the age of generative AI</div></div>
          </div>
        </div>
      </div>
    </div>
    <div class="seal" aria-label="人文共智"></div>
  </section>

  <!-- 3 · THE QUESTION CHANGED -->
  <section class="slide">
    <div class="inner">
      <div class="kicker r"><span class="num">02</span><span class="bar"></span> A shift of question</div>
      <h1 class="r" style="max-width:18ch">Not <em class="q">“will AI replace us?”</em><br>but <em class="q">“what AI do we want to build?”</em></h1>
      <p class="lead r" style="max-width:60ch">The anxious question assumed AI as an oracle that ends the conversation. We propose AI as a <strong>co-reader</strong> that opens it.</p>
      <div class="pull r" style="margin-top:4vh;max-width:42ch">AI does not replace interpretation;<br>it <em class="q">expands the space of interpretability.</em>
        <span class="small cjk">AI 並不取代詮釋，而是擴展人類可詮釋的空間。</span>
      </div>
    </div>
    <div class="seal" aria-label="人文共智"></div>
  </section>

  <!-- 4 · AGENTIC FLOW -->
  <section class="slide">
    <div class="inner">
      <div class="cols">
        <div>
          <div class="kicker r"><span class="num">03</span><span class="bar"></span> Agentic research flow</div>
          <h2 class="r">A seminar of agents,<br>and you in the chair.</h2>
          <p class="lead r" style="max-width:38ch">We move from one chatbot answer to a workflow of narrow specialists. Each plays a role, shows its sources, and flags its own uncertainty — the scholar stays in command.</p>
        </div>
        <div class="flow">
          <div class="step r"><div class="idx">1</div><div><div class="role">Variant critic <span class="zh cjk">異文</span></div><div class="desc">Detects lexical, syntactic &amp; structural divergence across versions.</div></div></div>
          <div class="step r"><div class="idx">2</div><div><div class="role">Translation analyst <span class="zh cjk">譯語</span></div><div class="desc">Reads each rendering's strategy — literal vs. interpretive.</div></div></div>
          <div class="step r"><div class="idx">3</div><div><div class="role">Doctrinal historian <span class="zh cjk">義理</span></div><div class="desc">Situates the passage in traditions — clearly marked as interpretation.</div></div></div>
          <div class="step r"><div class="idx">4</div><div><div class="role">Citation archivist <span class="zh cjk">來源</span></div><div class="desc">Pins every claim to a checkable source. Never invents one.</div></div></div>
        </div>
      </div>
    </div>
    <div class="seal" aria-label="人文共智"></div>
  </section>

  <!-- 5 · SUTRALENS DEMO -->
  <section class="slide">
    <div class="inner">
      <div class="kicker r"><span class="num">04</span><span class="bar"></span> Prototype I · SutraLens — a scholarly microscope</div>
      <div class="sutra r">
        <div class="panel">
          <div class="head">Version A <span class="who cjk">鳩摩羅什 Kumārajīva</span></div>
          <div class="scripture">
            <span class="dim">…菩薩應如是生清淨心，不應住色生心，</span><br>
            <span class="phrase" id="phraseA" onclick="sutraSelect()">應無所住而生其心</span><span class="dim">。</span>
          </div>
          <div class="hint-tap">Tap the highlighted line →</div>
        </div>
        <div class="panel">
          <div class="head">Version B <span class="who cjk">玄奘系 Xuanzang trad.</span></div>
          <div class="scripture">
            <span class="dim">…菩薩如是都無所住而生其心，</span><br>
            <span class="phrase" id="phraseB">不住於相而起其心</span><span class="dim">。</span>
          </div>
          <div class="hint-tap cjk">語意對齊，字句相異</div>
        </div>
        <div class="panel agent-panel">
          <div class="proto-tag">concept prototype · local-first</div>
          <div class="head">AI Scholarly Panel</div>
          <div class="tabs" id="tabs" style="display:none">
            <button class="tab on" data-a="variant" onclick="showAgent('variant',this)">Variant</button>
            <button class="tab" data-a="translation" onclick="showAgent('translation',this)">Translation</button>
            <button class="tab" data-a="doctrinal" onclick="showAgent('doctrinal',this)">Doctrinal</button>
            <button class="tab" data-a="citation" onclick="showAgent('citation',this)">Citation</button>
          </div>
          <div class="agent-body empty" id="agentBody">Select a passage to convene the agents.</div>
        </div>
      </div>
    </div>
    <div class="seal" aria-label="人文共智"></div>
  </section>

  <!-- 6 · 情 FIELD -->
  <section class="slide">
    <div class="inner">
      <div class="kicker r"><span class="num">05</span><span class="bar"></span> Prototype II · The geometry of feeling</div>
      <div class="field-wrap">
        <div class="field-box r">
          <svg id="qingField" viewBox="0 0 1040 640" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <marker id="ah" markerWidth="6" markerHeight="6" refX="4.5" refY="3" orient="auto">
                <path d="M0,0 L5,3 L0,6 Z" fill="#3a4a7a"/>
              </marker>
              <marker id="ahBig" markerWidth="9" markerHeight="9" refX="6" refY="4.5" orient="auto">
                <path d="M0,0 L8,4.5 L0,9 Z" fill="#B23A2E"/>
              </marker>
            </defs>
            <rect x="40" y="34" width="960" height="572" rx="16" fill="none" stroke="rgba(27,42,74,.18)"/>
            <g id="fieldArrows"></g>
            <path d="M 196 486 C 360 470, 452 372, 556 318 S 760 196, 868 150" fill="none" stroke="#1B2A4A" stroke-width="3.4" marker-end="url(#ahBig)" opacity=".92"/>
            <path d="M 196 486 C 360 470, 452 372, 556 318 S 760 196, 868 150" fill="none" stroke="#1B2A4A" stroke-width="3.4" stroke-dasharray="2 9" opacity=".25"/>
            <circle cx="430" cy="392" r="3" fill="#42527A"/><text x="438" y="396" font-family="Libre Franklin" font-size="15" fill="#6E6552" font-style="italic">feeling</text>
            <circle cx="556" cy="318" r="3" fill="#42527A"/><text x="564" y="322" font-family="Libre Franklin" font-size="15" fill="#6E6552" font-style="italic">passion</text>
            <circle cx="712" cy="232" r="3" fill="#42527A"/><text x="606" y="252" font-family="Libre Franklin" font-size="15" fill="#6E6552" font-style="italic">situation</text>
            <circle cx="196" cy="486" r="7" fill="#1B2A4A"/>
            <text x="150" y="528" font-family="Noto Serif TC" font-size="38" font-weight="600" fill="#1B2A4A" opacity=".18">情</text>
            <text x="196" y="556" text-anchor="middle" font-family="Libre Franklin" font-size="15" font-weight="600" fill="#1B2A4A">情 · Classical (c. 1700)</text>
            <circle cx="868" cy="150" r="8" fill="#B23A2E"/>
            <text x="828" y="120" font-family="Noto Serif TC" font-size="40" font-weight="700" fill="#B23A2E" opacity=".9">情</text>
            <text x="868" y="100" text-anchor="middle" font-family="Libre Franklin" font-size="15" font-weight="600" fill="#B23A2E">Modern</text>
            <text x="70"  y="78"  font-family="Libre Franklin" font-size="15" font-weight="600" fill="#42527A">Affective State</text>
            <text x="70"  y="98"  font-family="Noto Serif TC" font-size="14" fill="#5E7E6E">情感／情緒</text>
            <text x="70"  y="250" font-family="Libre Franklin" font-size="15" font-weight="600" fill="#42527A">Affection / Affinity</text>
            <text x="70"  y="270" font-family="Noto Serif TC" font-size="14" fill="#5E7E6E">情趣／情味</text>
            <text x="120" y="588" font-family="Libre Franklin" font-size="15" font-weight="600" fill="#42527A">Social Bond</text>
            <text x="470" y="592" font-family="Libre Franklin" font-size="15" font-weight="600" fill="#42527A">Local Customs</text>
            <text x="800" y="320" font-family="Libre Franklin" font-size="15" font-weight="600" fill="#42527A">Stance / Attitude</text>
            <text x="720" y="62"  font-family="Libre Franklin" font-size="15" font-weight="600" fill="#42527A">Condition / Situation</text>
            <text x="720" y="82"  font-family="Noto Serif TC" font-size="14" fill="#5E7E6E">情況</text>
          </svg>
        </div>
        <div class="field-note">
          <h2 class="r" style="margin-bottom:1.4vh">情 — three centuries of drift.</h2>
          <p class="lead r" style="margin-top:1vh;max-width:34ch">Embed a word diachronically, and the <strong>semantic space itself becomes a field.</strong> Each word leaves a shift-vector; together they map a culture's changing structure of feeling.</p>
          <div class="formula r">Δs(情) = <b>‖ v(情, t₁→t₂) ‖</b> &nbsp;— the machine draws the map; <em style="font-style:italic">hermeneutics reads the territory.</em></div>
          <div class="cite r">Hsieh &amp; Chen (forthcoming) · Sinographia Diachronica</div>
        </div>
      </div>
    </div>
    <div class="seal" aria-label="人文共智"></div>
  </section>

  <!-- 7 · CHAI.md -->
  <section class="slide">
    <div class="inner">
      <div class="cols">
        <div>
          <div class="kicker r"><span class="num">06</span><span class="bar"></span> From tools to co-intelligence</div>
          <h2 class="r">Every agent reads<br>a context file.<br>So should<br>the humanities.</h2>
          <p class="lead r" style="max-width:38ch">Engineers give their agents a <strong>CLAUDE.md / AGENTS.md</strong> — who you are, what you value, how to behave. We propose the humanities write theirs: <strong>CHAI.md.</strong> Not a static prompt, but a <em class="q">living constitution</em> that the AI reads, acts by, and refines through every encounter with a scholar and a text.</p>
        </div>
        <div class="mdcard r">
          <div class="fn"># CHAI.md — a humanities–AI organism</div>
          <span class="c">## identity</span><br>
          <span class="k">role:</span> <span class="v">co-reader, not oracle</span><br>
          <span class="k">posture:</span> <span class="v">expand interpretability</span><br><br>
          <span class="c">## values</span><br>
          <span class="k">- </span><span class="v">plurality of interpretation</span><br>
          <span class="k">- </span><span class="v">provenance over fluency</span><br>
          <span class="k">- </span><span class="v">minority languages &amp; memory</span><br><br>
          <span class="c">## practice</span><br>
          <span class="k">always:</span> <span class="v">cite · flag uncertainty</span><br>
          <span class="k">never:</span> <span class="v">invent a source</span><br><br>
          <span class="c"># refined with every reading…</span><span class="cursor"></span>
        </div>
      </div>
    </div>
    <div class="seal" aria-label="人文共智"></div>
  </section>

  <!-- 8 · GOVERNANCE -->
  <section class="slide">
    <div class="inner">
      <div class="kicker r"><span class="num">07</span><span class="bar"></span> Why this matters beyond research</div>
      <h1 class="r" style="max-width:20ch">Sending culture<br>a delegate.</h1>
      <p class="lead r" style="max-width:58ch">Soon, much of our institutional life will run on AI whose norms are set elsewhere — in code, policy, defaults. If the humanities are absent from that table, our values go <strong>unrepresented.</strong></p>
      <div class="pull r" style="margin-top:4vh;max-width:50ch">An AI raised on a CHAI.md is not only the most humanities-literate AI — it can <em class="q">advocate for humanistic value</em> inside the very systems that will govern us.
        <span class="small">Internalizing culture is step one. Defending it is the point.</span>
      </div>
    </div>
    <div class="seal" aria-label="人文共智"></div>
  </section>

  <!-- 9 · CLOSING / ALLIANCE -->
  <section class="slide">
    <div class="inner">
      <div class="kicker r"><span class="num">08</span><span class="bar"></span> An East Asian alliance</div>
      <h2 class="r" style="max-width:24ch">No single model has truly seen our archives.<br>Together, we can change that.</h2>
      <div class="alliance r">
        <div class="uni"><div class="en">National Taiwan U.</div><div class="nat cjk">國立臺灣大學</div></div>
        <div class="uni"><div class="en">Kyushu University</div><div class="nat cjk">九州大学</div></div>
        <div class="uni"><div class="en">Kyoto University</div><div class="nat cjk">京都大学</div></div>
        <div class="uni"><div class="en">Korea University</div><div class="nat cjk">고려대학교</div></div>
      </div>
      <div class="slogan r">From parallel reading to <span class="em">semantic co-reading.</span><br>From tools to <span class="em">co-intelligence.</span></div>
      <div class="thanks r"><span>Thank you</span><span>ありがとうございます</span><span>감사합니다</span><span>謝謝</span></div>
    </div>
    <div class="seal" aria-label="人文共智"></div>
  </section>

</div>

<div class="nav">
  <div class="arrow" onclick="go(-1)">‹</div>
  <div class="dots" id="dots"></div>
  <div class="arrow" onclick="go(1)">›</div>
</div>
<div class="help"><kbd>←</kbd> <kbd>→</kbd> move · <kbd>N</kbd> notes · <kbd>F</kbd> fullscreen</div>

<div class="notes" id="notes">
  <div class="lbl">Presenter notes · <span id="noteNum">01</span></div>
  <p id="noteText"></p>
</div>

<script>
const slides=[...document.querySelectorAll('.slide')];
const total=slides.length;
let idx=0;
document.getElementById('tot').textContent=String(total).padStart(2,'0');

const dotsWrap=document.getElementById('dots');
slides.forEach((_,i)=>{const d=document.createElement('div');d.className='dot-nav'+(i===0?' on':'');d.onclick=()=>jump(i);dotsWrap.appendChild(d);});
const dots=[...dotsWrap.children];

const notes=[
 "Good morning. 九州大学、京都大学、고려대학교の先生方 — welcome to Taipei, and thank you for joining this first TRIP gathering. My title today is Humanities AI in an East Asian Context. In ten minutes I won't show a finished product but a direction — what we at NTU's College of Liberal Arts call CHAI: the Co-Intelligence of Humanities and AI. The word also means 'tea' — something East Asia has long known how to cultivate slowly, attentively, and together.",
 "We have entered an age of cheap fluency and expensive meaning. When any system can generate plausible text in any voice at almost no cost, fluency stops being scarce. What becomes scarce — and therefore precious — is meaning: interpretation, provenance, judgment, the weight of a word across centuries. These are exactly the competencies the humanities have cultivated for two thousand years. So the humanities don't merely survive AI; AI raises their value. The flood of generated language is precisely why we need cartographers of meaning.",
 "For a while the anxious question was: will AI replace the humanist? I think that's the wrong question. The better one is: what kind of AI do the humanities want to build? Our guiding principle is simple — AI does not replace interpretation; it expands the space of interpretability. Not an oracle that ends the conversation, but a co-reader that opens it.",
 "Concretely, this means moving from a single chatbot answer to an agentic research flow. Think of it as a research seminar that you chair: one agent is the textual critic, one the translator, one the doctrinal historian, one the archivist who insists on citations. Each has a narrow role; each must show its sources and flag its uncertainty; you stay in the chair. Let me show two prototypes.",
 "The first is SutraLens — AI-augmented aligned reading for Buddhist texts. Here are two renderings of one line of the Diamond Sutra. Kumārajīva: 'give rise to the mind that abides nowhere.' The Xuanzang tradition foregrounds 相 — appearance. I select the phrase, and four scholarly agents respond. [Tap it.] The Variant agent marks the lexical divergence; the Translation agent reads it as aphoristic compression versus analytic clarity; the Doctrinal agent situates it in emptiness and later Chan practice — clearly labelled as interpretation, not verdict; the Citation agent pins everything to Taishō 235. Crucially, it runs on local models — data sovereignty for our cultural archives — and it never invents a source. AI as a scholarly microscope, accountable to the text.",
 "The second prototype turns meaning into geometry. This is the word 情 — feeling — drifting across three centuries. We embed it diachronically, and the semantic space itself becomes a field. Each word leaves a shift-vector; together they form a vector field of cultural change. You can watch 情 travel from a classical cluster of affect and affinity toward the modern poles of 'condition' and 'situation' — 情況. The machine draws the map. But why a culture's structure of feeling moved this way — that reading stays ours. Distributional semantics gives the trajectory; hermeneutics gives the meaning.",
 "Now the vision. Engineers who work with AI agents know the convention of a context file — a CLAUDE.md, an AGENTS.md — that tells the agent who it is, what it values, how to behave. So we ask: what if the humanities wrote theirs? We call it CHAI.md. Not a static prompt, but a living constitution of humanistic knowledge and interpretive norms — one that the AI reads, acts by, and refines through every encounter with a scholar and a text. A humanities–AI organism that learns the humanities by practicing them.",
 "And this is more than internalizing culture. Soon, much of our institutional life will be mediated by AI whose norms are set elsewhere — in code, in policy, in defaults. If the humanities are absent from that table, our values — plurality of interpretation, provenance, minority languages, cultural memory — simply won't be represented. An AI raised on a CHAI.md is not only the most humanities-literate AI; it can become an advocate for humanistic value inside the very systems that will govern us. We're not just teaching machines about culture — we're sending culture a delegate.",
 "We can't, and shouldn't, build this alone. CHAI is conceived as an East Asian alliance — Taiwan, Kyushu, Kyoto, Korea — each bringing archives, languages, and traditions of reading that no single model has ever truly seen. Together we can cultivate the AI that best understands the humanities. From parallel reading to semantic co-reading; from tools to co-intelligence. ありがとうございます。 감사합니다。 謝謝。 Thank you."
];

function render(){
  slides.forEach((s,i)=>s.classList.toggle('active',i===idx));
  dots.forEach((d,i)=>d.classList.toggle('on',i===idx));
  document.getElementById('cur').textContent=String(idx+1).padStart(2,'0');
  document.getElementById('fill').style.width=((idx+1)/total*100)+'%';
  document.getElementById('noteNum').textContent=String(idx+1).padStart(2,'0');
  document.getElementById('noteText').textContent=notes[idx];
}
function go(n){idx=Math.min(total-1,Math.max(0,idx+n));render();}
function jump(i){idx=i;render();}

document.addEventListener('keydown',e=>{
  if(e.key==='ArrowRight'||e.key==='PageDown'){go(1);}
  else if(e.key==='ArrowLeft'||e.key==='PageUp'){go(-1);}
  else if(e.key===' '){e.preventDefault();go(1);}
  else if(e.key==='Home'){jump(0);}
  else if(e.key==='End'){jump(total-1);}
  else if(e.key.toLowerCase()==='n'){document.getElementById('notes').classList.toggle('show');}
  else if(e.key.toLowerCase()==='f'){if(!document.fullscreenElement)document.documentElement.requestFullscreen();else document.exitFullscreen();}
});

const agents={
 variant:{t:"Variant Agent",c:"med",cl:"medium",h:"Both renderings point to a <b>non-abiding mind</b>, yet diverge lexically. Kumārajīva foregrounds 住 (to abide / dwell); the comparison foregrounds 相 (mark, appearance). Semantically aligned — not identical.",ev:"evidence · diamond_kjv_001 ⇄ diamond_xz_001"},
 translation:{t:"Translation Agent",c:"med",cl:"medium",h:"Kumārajīva is concise and aphoristic; the alternate rendering makes the doctrinal object 相 explicit. A choice between <b>aesthetic compression</b> and <b>analytic clarity</b>.",ev:"evidence · diamond_kjv_001 ⇄ diamond_xz_001"},
 doctrinal:{t:"Doctrinal Agent",c:"low",cl:"low–medium",h:"Reads against 般若 (prajñā) emptiness and non-attachment; later absorbed into Chan readings of mind-practice. <b>Interpretive, not settled</b> — offered as a possibility, not a verdict.",ev:"interpretive inference · marked as such"},
 citation:{t:"Citation Agent",c:"med",cl:"checkable",h:"<b>T235, 8.749c</b> — 應無所住而生其心。 Direct textual evidence is kept distinct from interpretive inference. No source is generated.",ev:"source · Taishō Tripiṭaka 235"}
};
function sutraSelect(){
  document.getElementById('phraseA').classList.add('lit');
  document.getElementById('phraseB').classList.add('matched');
  document.getElementById('tabs').style.display='flex';
  showAgent('variant',document.querySelector('.tab[data-a="variant"]'));
}
function showAgent(key,btn){
  document.querySelectorAll('.tab').forEach(t=>t.classList.toggle('on',t===btn));
  const a=agents[key];const body=document.getElementById('agentBody');
  body.classList.remove('empty');
  body.innerHTML=`<div>${a.h}</div><div class="conf">confidence <span class="badge ${a.c}">${a.cl}</span></div><span class="ev">${a.ev}</span>`;
}

(function(){
  const svg=document.getElementById('fieldArrows');const NS='http://www.w3.org/2000/svg';
  const mx=868,my=150,ax=196,ay=486,step=46,len=15;
  for(let x=78;x<=996;x+=step){
    for(let y=70;y<=588;y+=step){
      let dx=mx-x,dy=my-y;const dist=Math.hypot(dx,dy)||1;dx/=dist;dy/=dist;
      const swirl=0.55;
      const fx=dx*Math.cos(swirl)-dy*Math.sin(swirl);
      const fy=dx*Math.sin(swirl)+dy*Math.cos(swirl);
      const ang=Math.atan2(fy,fx);
      const t=Math.max(0,Math.min(1,((x-ax)*(mx-ax)+(y-ay)*(my-ay))/(((mx-ax)**2+(my-ay)**2))));
      const px=ax+t*(mx-ax),py=ay+t*(my-ay);const near=Math.hypot(x-px,y-py);
      const op=near<90?0.34:(near<180?0.20:0.10);
      const ln=document.createElementNS(NS,'line');
      const x2=x+Math.cos(ang)*len,y2=y+Math.sin(ang)*len;
      ln.setAttribute('x1',x.toFixed(1));ln.setAttribute('y1',y.toFixed(1));
      ln.setAttribute('x2',x2.toFixed(1));ln.setAttribute('y2',y2.toFixed(1));
      ln.setAttribute('stroke','#3a4a7a');ln.setAttribute('stroke-width','1.4');
      ln.setAttribute('opacity',op.toFixed(2));ln.setAttribute('marker-end','url(#ah)');
      svg.appendChild(ln);
    }
  }
})();

render();
</script>
</body>
</html>
